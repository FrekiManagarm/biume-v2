{
    "name": "biume",
    "private": true,
    "workspaces": {
        "packages": [
            "apps/*",
            "packages/*"
        ],
        "catalog": {
            "dotenv": "^17.2.2",
            "zod": "^4.1.13",
            "typescript": "^6",
            "@types/node": "^22.13.14",
            "next-themes": "^0.4.6",
            "better-auth": "1.6.9",
            "@types/react-dom": "^19.2.3",
            "react": "19.2.7",
            "react-dom": "19.2.7"
        }
    },
    "type": "module",
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "check-types": "turbo check-types",
        "dev:app": "turbo -F web dev",
        "dev:marketing": "turbo -F marketing dev",
        "dev:web": "turbo -F web dev",
        "db:push": "turbo -F @biume/db db:push",
        "db:studio": "turbo -F @biume/db db:studio",
        "db:generate": "turbo -F @biume/db db:generate",
        "db:migrate": "turbo -F @biume/db db:migrate"
    },
    "dependencies": {
        "@biume/env": "workspace:*",
        "dotenv": "catalog:",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@biume/config": "workspace:*",
        "@types/node": "catalog:",
        "turbo": "^2.8.12",
        "typescript": "catalog:"
    },
    "packageManager": "bun@1.3.11",
    "patchedDependencies": {
        "nf3@0.3.18": "patches/nf3@0.3.18.patch"
    }
}
